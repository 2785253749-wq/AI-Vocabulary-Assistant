# 数据库连接
# 数据库连接（SQLite使用绝对路径，部署时改为MySQL连接字符串）
DATABASE_URL=sqlite:///D:/path/to/project/database/app.db

# DeepSeek API密钥
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# JWT密钥（生产环境请使用随机字符串）
JWT_SECRET_KEY=your-jwt-secret-key-change-me

# 运行环境：development / production / testing
FLASK_ENV=development
